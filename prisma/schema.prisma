generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  MANAGER
  ADMIN
  HOSTESS
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(HOSTESS)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Event {
  id                String    @id @default(cuid())
  externalId        String?   @unique
  title             String
  city              String
  address           String
  features          String    @default("")
  gameRules         String    @default("")
  gameType          String
  startsAt          DateTime
  endsAt            DateTime?
  participantLimit  Int
  imageUrl          String?
  imageHash         String?
  status            String    @default("draft")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  registrationCount Int

  // registrations EventRegistration[]
}
