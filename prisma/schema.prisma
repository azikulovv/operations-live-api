generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  MANAGER
  ADMIN
  HOSTESS
  BARTENDER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(HOSTESS)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Event {
  id                 String                  @id @default(cuid())
  externalId         String                  @unique
  title              String
  city               String
  address            String
  gameType           String
  startsAt           DateTime
  endsAt             DateTime?
  status             String
  participantLimit   Int?
  initialDepositAmount Int     @default(0)
  seatsPerTable      Int?
  tableCount         Int
  registrationsCount Int
  participants       EventParticipant[]
  tables             EventTable[]
  finalTablePlayers  ParticipantFinalTable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startsAt])
  @@map("events")
}

model EventParticipant {
  id             String                    @id @default(cuid())
  externalId     String                    @unique
  externalUserId String
  eventId        String
  status         String
  registeredAt   DateTime
  cancelledAt    DateTime?
  position       Int?
  tableNumber    Int?
  seatNumber     Int?
  userName       String?
  userEmail      String?
  userPhone      String?
  userTelegramId String?
  userAvatarUrl  String?
  badge          String?
  initialDepositAmount Int     @default(0)
  arrived        Boolean                   @default(false)
  promotion      ParticipantPromotion?
  payment        ParticipantPayment?
  bartenderSale  ParticipantBartenderSale?
  debt           ParticipantDebt?
  tournament     ParticipantTournament?
  finalTable     ParticipantFinalTable?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventId])
  @@map("event_participants")
}

model EventTable {
  id           String  @id @default(cuid())
  eventId      String
  tableNumber  Int
  playersCount Int     @default(0)
  maxPlayers   Int     @default(9)
  status       String  @default("NOT_USED")
  comment      String?

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, tableNumber])
  @@index([eventId])
  @@map("event_tables")
}

model ParticipantPromotion {
  id              String  @id @default(cuid())
  participantId   String  @unique
  promotionType   String?
  reason          String?
  discountPercent Int     @default(0)
  used            Int     @default(0)
  comment         String?

  participant EventParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("participant_promotions")
}

model ParticipantPayment {
  id                    String  @id @default(cuid())
  participantId         String  @unique
  accruedAmount         Int     @default(0)
  discountAmount        Int     @default(0)
  paidAmount            Int     @default(0)
  status                String  @default("UNPAID")
  comment               String?

  participant EventParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("participant_payments")
}

model ParticipantBartenderSale {
  id            String  @id @default(cuid())
  participantId String  @unique
  amount        Int     @default(0)
  comment       String?

  participant EventParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("participant_bartender_sales")
}

model ParticipantDebt {
  id            String  @id @default(cuid())
  participantId String  @unique
  amount        Int     @default(0)
  comment       String?
  closed        Boolean @default(false)

  participant EventParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("participant_debts")
}

model ParticipantTournament {
  id            String @id @default(cuid())
  participantId String @unique
  reEntry       Int    @default(0)
  addon         Int    @default(0)
  knockouts     Int    @default(0)
  bustoutOrder  Int    @default(0)
  status        String @default("ACTIVE")

  participant EventParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("participant_tournaments")
}

model ParticipantFinalTable {
  id            String @id @default(cuid())
  eventId       String
  participantId String @unique
  seat          Int
  stack         Int    @default(0)

  event       Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant EventParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([eventId, seat])
  @@index([eventId])
  @@map("participant_final_tables")
}
