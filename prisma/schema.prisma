generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  MANAGER
  ADMIN
  HOSTESS
  BARTENDER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(HOSTESS)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Event {
  id                 String    @id @default(cuid())
  externalId         String    @unique
  title              String
  city               String
  address            String
  gameType           String
  startsAt           DateTime
  endsAt             DateTime?
  status             String
  participantLimit   Int?
  seatsPerTable      Int?
  tableCount         Int
  registrationsCount Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startsAt])
  @@map("events")
}
