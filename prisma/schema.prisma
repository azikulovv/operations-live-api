generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  MANAGER
  ADMIN
  HOSTESS
  BARTENDER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(HOSTESS)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}
